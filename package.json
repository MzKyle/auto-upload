{
  "name": "electron-uploader",
  "version": "1.0.0",
  "description": "数据采集文件夹上传工具",
  "author": {
    "name": "WeldingTeam",
    "email": "welding@example.com"
  },
  "homepage": "https://github.com/welding/electron-uploader",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint .",
    "build:linux": "electron-vite build && rm -rf node_modules/cpu-features && electron-builder --linux --x64 && npx electron-rebuild -f -w better-sqlite3",
    "build:win": "electron-vite build && electron-builder --win --x64 && npx electron-rebuild -f -w better-sqlite3",
    "build:all": "electron-vite build && electron-builder --linux --win --x64 && npx electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "ali-oss": "^6.21.0",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.3",
    "electron-log": "^5.3.0",
    "konva": "^10.2.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.14",
    "react-router-dom": "^7.1.0",
    "ssh2": "^1.16.0",
    "uuid": "^11.0.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/ali-oss": "^6.16.11",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ssh2": "^1.15.4",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "postcss": "^8.4.49",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}